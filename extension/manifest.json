{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "1.0",
  "description": "AI-powered phishing email detection extension",

  "action": {
    "default_popup": "popup/popup.html"
  },

  "permissions": [
    "activeTab",
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "*://mail.google.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://mail.google.com/*"],
      "js": ["scripts/content.js"],
      "run_at": "document_idle"
    }
  ]
}
